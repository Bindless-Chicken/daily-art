        {
          "id": "200110515",
          "name": "Portrait of a Woman",
          "timespan": "1548",
          "artist": "Catharina van Hemessen",
          "material": "oil on panel",
          "dimensions": "height 34.7 cm x width 27 cm x depth 2.5 cm",
          "exhibitScript": "The self-assured Catharina van Hemessen signed and dated this portrait of an unknown woman. In large gilt letters, she inscribed in Latin ‘Catherina de Hemessen pinxit 1548,’ which translates as ‘Catharina van Hemessen painted this in 1548.’ Van Hemessen is the first Southern Netherlandish female painter by whom signed and dated works are known. This portrait is likely one of her earliest pieces.",
          "tags": [],
          "imageUrl": "https://iiif.micr.io/gtsVg/full/max/0/default.jpg",
          "origin": {
