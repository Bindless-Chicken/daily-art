            "url": "https://www.rijksmuseum.nl/"
          }
        },
        {
          "id": "200107778",
          "name": "Portrait of Johannes Hudde (1628-1704), burgomaster of Amsterdam",
          "timespan": "1686",
          "artist": "Michiel van Musscher",
          "material": "oil on canvas",
          "dimensions": "depth 6 cm",
          "exhibitScript": "Michiel van Musscher, a pupil of Gabriel Metsu, painted this portrait with great precision. The sitter, Johannes Hudde, wears a morning gown made of Chinese silk, known in Dutch as a ‘Japanse rok.’ While it was de rigueur to wear this type of garment around the house, it was also likely meant to reference his role as a Dutch East India Company (VOC) administrator. The large book on the table with the most important rights or charters of Amsterdam makes it clear that Hudde was also a burgomaster of that city.",
          "tags": [
            "https://id.rijksmuseum.nl/2216203",
            "https://id.rijksmuseum.nl/2211662",
            "https://id.rijksmuseum.nl/22123"
          ],
