      "options": [
        {
          "id": "200109368",
          "name": "Andries Bicker (1586-1652). Trader with Russia and Burgomaster of Amsterdam",
          "timespan": "1642",
          "artist": "Bartholomeus van der Helst",
          "material": "oil on panel",
          "dimensions": "height 93.5 cm x width 70.5 cm",
          "exhibitScript": "Andries Bicker, a merchant in Russia and dealer in spices, wielded enormous administrative power. He was elected mayor of Amsterdam ten times, represented the city in the States-General, and served as ambassador to the Scandinavian nations, Poland and the Duchy of Brandenburg. When he sat to the celebrated Amsterdam portraitist Van der Helst, the Bickers were the most powerful family in the city.",
          "tags": [
            "https://id.rijksmuseum.nl/22123",
            "https://id.rijksmuseum.nl/221943",
            "https://id.rijksmuseum.nl/2211662"
          ],
          "imageUrl": "https://iiif.micr.io/SjURy/full/max/0/default.jpg",
          "origin": {
